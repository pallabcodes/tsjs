{
  "name": "zen-tui",
  "version": "0.1.0",
  "private": true,
  "description": "A high-performance Git TUI client powered by custom ZenEngine and SolidJS",
  "type": "module",
  "scripts": {
    "dev": "pnpm -w zbt build apps/zen-tui && ../../apps/zentui-host/target/release/zentui-host dist/host.js",
    "start": "../../apps/zentui-host/target/release/zentui-host dist/host.js",
    "build": "pnpm -w zbt build apps/zen-tui"
  },
  "napi": {
    "name": "zen_tui_native",
    "packageName": "zen-tui-native",
    "packageJsonPath": ".."
  },
  "dependencies": {
    "@zen-tui/core": "workspace:*",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@napi-rs/wasm-runtime": "^1.1.1",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
