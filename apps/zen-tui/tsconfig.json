{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "paths": {
      "zen-reconciler": ["./src/engine/reconciler.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "native", "research"]
}
