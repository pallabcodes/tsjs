{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "zen-reconciler": ["./src/engine/reconciler.ts"],
      "@zen-tui/*": ["../../packages/zen-tui-*/src/index.ts"],
      "@zen-tui/solid": ["../../packages/zen-tui-solid/src/index.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "native", "research", "**/*.concept.ts", "**/*.concept.tsx"]
}
