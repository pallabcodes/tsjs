{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@zen-tui/core",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "types": ["bun-types", "node"],
    "baseUrl": ".",
    "paths": {
      "@zentui/core": ["../../packages/zen-tui-core/src/index.tsx"],
      "@zen-tui/*": ["../../packages/zen-tui-*/src/index.ts"],
      "@zen-tui/core": ["../../packages/zen-tui-core/src/index.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "native", "research", "**/*.concept.ts", "**/*.concept.tsx"]
}
