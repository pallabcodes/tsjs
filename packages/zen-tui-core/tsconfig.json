{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@zen/layout": ["../../zen-layout/src/index.ts"],
      "@zen/painter": ["../../zen-painter/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
