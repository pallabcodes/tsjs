# OStream Multi-Language Monorepo .gitignore

# Node.js
node_modules/
dist/
dist-ssr/
build/
*.tsbuildinfo
.turbo/
.npm/
.eslintcache

# Go (Telemetry)
vendor/
*.exe
*.test
*.prof
__debug_bin

# Java (Policy)
target/
*.class
*.jar
*.war
*.ear
.factorypath
.project
.settings/
.classpath

# C++ (Media)
bin/
obj/
*.o
*.obj
*.so
*.a
*.lib
*.dll
cmake-build-*/
.cmake/

# OS / IDEs
.DS_Store
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
Thumbs.db

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
