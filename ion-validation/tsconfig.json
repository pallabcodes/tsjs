{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@foculist/ion": ["./packages/ion/src/index.ts"]
    }
  },
  "include": ["packages/ion/src/**/*", "scratch/**/*.ts"]
}
