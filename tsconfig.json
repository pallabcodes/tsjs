{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@zen-tui/core",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@zen-tui/core": ["packages/zen-tui-core/src/index.tsx"],
      "@zen-tui/node": ["packages/zen-tui-node/src/index.ts"],
      "@zen-tui/native": ["packages/zen-tui-native/src/index.ts"],
      "@/*": ["apps/zen-tui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
