{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@zen-tui/core": ["packages/zen-tui-core/src/index.ts"],
      "@zen-tui/layout": ["packages/zen-tui-layout/src/index.ts"],
      "@zen-tui/painter": ["packages/zen-tui-painter/src/index.ts"],
      "@zen-tui/solid": ["packages/zen-tui-solid/src/index.ts"],
      "@/*": ["apps/zen-tui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
