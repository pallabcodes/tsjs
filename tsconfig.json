{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@tsjs/core": ["packages/core/src/index.ts"],
      "@tsjs/dsa": ["packages/dsa/src/index.ts"],
      "@tsjs/patterns": ["packages/patterns/src/index.ts"],
      "@tsjs/knowledge": ["packages/knowledge/src/index.ts"],
      "@tsjs/frameworks": ["packages/frameworks/src/index.ts"],
      "@tsjs/learning-lab": ["apps/learning-lab/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
