{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@native/*": ["src/native/*"],
      "@zen-tui/core": ["packages/zen-tui-core/src/index.ts"],
      "@zen-tui/solid": ["packages/zen-tui-solid/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
